# ==============================================================================
# Gmail PDF Invoice Parser Configuration Template
# 複製此檔案並重新命名為 .env，然後填入您的設定值。
# ==============================================================================

# Google Sheet 設定
# 您的 Google Sheet 網址中的長字串（例如：https://docs.google.com/spreadsheets/d/YOUR_SPREADSHEET_ID/edit）
SPREADSHEET_ID=your_google_sheet_id_here
# 工作表名稱（例如：工作表1 或 Sheet1）
SHEET_NAME=Sheet1

# Gmail 搜尋條件
GMAIL_SEARCH_QUERY='"發票" OR (subject:(收據 OR receipt OR invoice) has:attachment filename:pdf)'

# 解析模式選擇：'local' (使用 pdfplumber 本地正則表達式) 或 'gemini' (使用 Gemini API) 或 'claude' (使用 Claude API)
PARSER_MODE=local

# LLM API 金鑰 (如果 PARSER_MODE 設定為 'gemini' 或 'claude' 才需要填寫)
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
